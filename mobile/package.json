{
  "name": "fleet-telemetry-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "export": "expo export --platform android"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-crypto": "~15.0.9",
    "expo-location": "~19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "coverageReporters": [
      "text",
      "json-summary"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.ts",
      "src/db/**/*.ts",
      "src/hooks/**/*.ts",
      "!src/**/*.test.ts",
      "!src/types/**",
      "!src/**/*.d.ts"
    ]
  }
}
