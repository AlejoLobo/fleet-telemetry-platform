{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "TelemetryTopic": "telemetry.raw",
    "DeadLetterTopic": "telemetry.dead-letter",
    "RealtimeTopic": "fleet.realtime",
    "ConsumerGroup": "telemetry-processor",
    "MaxProcessingAttempts": 3,
    "RetryInitialDelayMilliseconds": 500,
    "RetryMaxDelayMilliseconds": 5000,
    "MaxDeadLetterPublishAttempts": 5,
    "MaxPollIntervalMilliseconds": 300000
  },
  "TimescaleDb": {
    "ConnectionString": "Host=localhost;Port=5432;Database=fleet;Username=fleet;Password=fleet"
  },
  "Resilience": {
    "Kafka": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 200
    },
    "TimescaleDb": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 250
    }
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "FleetTelemetry.Worker",
    "OtlpEndpoint": "http://localhost:4317",
    "OtlpProtocol": "grpc"
  }
}
