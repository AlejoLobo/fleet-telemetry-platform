{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "TelemetryTopic": "telemetry.raw",
    "DlqTopic": "telemetry.dlq",
    "ConsumerGroup": "telemetry-processor",
    "MaxProcessingAttempts": 3
  },
  "TimescaleDb": {
    "ConnectionString": "Host=localhost;Port=5432;Database=fleet;Username=fleet;Password=fleet"
  },
  "Resilience": {
    "Kafka": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 200
    },
    "TimescaleDb": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 250
    }
  }
}
