{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "TelemetryTopic": "telemetry.raw",
    "DeadLetterTopic": "telemetry.dead-letter",
    "ConsumerGroup": "telemetry-processor"
  },
  "TimescaleDb": {
    "ConnectionString": "Host=localhost;Port=5432;Database=fleet;Username=fleet;Password=fleet"
  },
  "Auth": {
    "Enabled": false,
    "JwtSecret": "fleet-telemetry-dev-secret-change-in-production-min-32-chars",
    "JwtIssuer": "fleet-telemetry",
    "JwtAudience": "fleet-clients",
    "TokenExpirationMinutes": 480,
    "DemoUsername": "admin",
    "DemoPassword": "fleet2026"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "BaseUrl": "https://api.openai.com/v1"
  },
  "Resilience": {
    "Kafka": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 200
    },
    "OpenAi": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 4,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 20,
      "MaxRetryAttempts": 2,
      "RetryDelayMilliseconds": 300
    },
    "TimescaleDb": {
      "Enabled": true,
      "FailureRatio": 0.5,
      "MinimumThroughput": 5,
      "SamplingDurationSeconds": 30,
      "BreakDurationSeconds": 30,
      "MaxRetryAttempts": 3,
      "RetryDelayMilliseconds": 250
    }
  },
  "Sse": {
    "ActivePollIntervalSeconds": 3,
    "IdlePollIntervalSeconds": 10
  }
}
