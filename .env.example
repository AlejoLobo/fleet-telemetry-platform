ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# Kafka (convención ASP.NET: Kafka__*)
Kafka__BootstrapServers=localhost:19092
Kafka__TelemetryTopic=telemetry.raw
Kafka__DeadLetterTopic=telemetry.dead-letter
Kafka__ConsumerGroup=telemetry-processor
Kafka__MaxProcessingAttempts=3
Kafka__RetryInitialDelayMilliseconds=500
Kafka__RetryMaxDelayMilliseconds=5000
Kafka__MaxDeadLetterPublishAttempts=5
Kafka__MaxPollIntervalMilliseconds=300000

# TimescaleDB
TimescaleDb__ConnectionString=Host=localhost;Port=5432;Database=fleet;Username=fleet;Password=fleet

# Auth (opcional; valores de demo — cambiar en entornos reales)
Auth__Enabled=false
# Requerido si Auth__Enabled=true (mínimo 32 caracteres)
Auth__JwtSecret=change-me-use-a-secret-with-at-least-32-characters
Auth__DemoUsername=admin
# Requerido si Auth__Enabled=true
Auth__DemoPassword=demo-password-change-me

# OpenAI (opcional; dejar vacío para deshabilitar pulido LLM)
OpenAI__ApiKey=

# SSE polling
Sse__ActivePollIntervalSeconds=3
Sse__IdlePollIntervalSeconds=10
